import streamlit as st
import random
from groq import Groq

# 1. PAGE CONFIG & STYLING
st.set_page_config(page_title="SANA CHAT BOT V11", layout="wide")

st.markdown("""
    <style>
    .stApp { background-color: #0e1117; color: white; }
